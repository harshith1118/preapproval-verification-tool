# .env.example
# Copy to .env and fill in any needed values.
# No secrets are required for the core MVP (PDF parsing + Playwright).

# Optional: LLM API keys for future field-extraction enhancements
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Playwright timeout (ms)
# PLAYWRIGHT_TIMEOUT_MS=30000

# Optional: Custom evidence/report directories (defaults to ./evidence and ./reports)
# EVIDENCE_DIR=./evidence
# REPORTS_DIR=./reports